                    const team1UpsetBadge = (game.isUpset && isTeam1Winner) ? '<span class="upset-badge">以弱胜强</span>' : '';
                    const team2UpsetBadge = (game.isUpset && !isTeam1Winner) ? '<span class="upset-badge">以弱胜强</span>' : '';

                    // 守备模式角标放在守备方一侧
                    const team1DefenseBadge = game.team1DefenseMode ? '<span class="defense-badge">守备模式</span>' : '';
                    const team2DefenseBadge = game.team2DefenseMode ? '<span class="defense-badge">守备模式</span>' : '';

                    // 守备模式详细信息
                    let defenseModeInfo = '';
