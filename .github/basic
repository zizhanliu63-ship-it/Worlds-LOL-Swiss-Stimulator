        // 生成增益明细HTML
        function generateBreakdownHTML(breakdown, basePower) {
            if (!breakdown || breakdown.length === 0) {
                return '<span>额外战力: +0 (0%)</span>';
            }

            let totalBonusPower = 0;
            let totalBonusPercent = 0;
            let html = '';

            breakdown.forEach(item => {
                const percentInt = Math.round(item.percent);
                html += `<span style="color: ${item.decay ? '#9C27B0' : '#4CAF50'};">${item.label}: +${item.power} (${percentInt}%)</span>`;
                totalBonusPower += item.power;
                totalBonusPercent += item.percent;
            });

            const totalPercentInt = Math.round(totalBonusPercent);
            html += `<span style="font-weight: 600; color: #FF9800;">合计额外战力: +${totalBonusPower} (${totalPercentInt}%)</span>`;

            return html;
        }

        // 生成数据分析HTML
        function generateAnalyticsHTML() {
            if (!currentMatch || !currentMatch.games || currentMatch.games.length === 0) return '';

            const games = currentMatch.games;
            const totalGames = games.length;
            const team1Wins = games.filter(g => g && g.winner && g.winner.id === currentMatch.team1.id).length;
            const team2Wins = games.filter(g => g && g.winner && g.winner.id === currentMatch.team2.id).length;
            const upsets = games.filter(g => g && g.isUpset).length;

            let avgPowerDiff = 0;
            games.forEach(g => {
                if (g) {
                    const diff = Math.abs((g.team1FinalPower || 0) - (g.team2FinalPower || 0));
                    avgPowerDiff += diff;
                }
            });
            avgPowerDiff = totalGames > 0 ? Math.round(avgPowerDiff / totalGames) : 0;

            let maxPowerDiff = 0;
            games.forEach(g => {
                if (g) {
                    const diff = Math.abs((g.team1FinalPower || 0) - (g.team2FinalPower || 0));
                    if (diff > maxPowerDiff) maxPowerDiff = diff;
                }
            });

            let avgWinRateDeviation = 0;
            games.forEach(g => {
                if (g && g.team1WinRate) {
                    const deviation = Math.abs(parseFloat(g.team1WinRate) - 50);
                    avgWinRateDeviation += deviation;
                }
            });
            avgWinRateDeviation = totalGames > 0 ? (avgWinRateDeviation / totalGames).toFixed(1) : '0.0';

            return `
                <div class="analytics-section">
                    <h4>本场数据分析</h4>
                    <div class="analytics-grid">
                        <div class="analytics-card">
                            <div class="analytics-value">${totalGames}</div>
                            <div class="analytics-label">已进行局数</div>
                        </div>
                        <div class="analytics-card">
                            <div class="analytics-value">${upsets}</div>
                            <div class="analytics-label">以弱胜强次数</div>
                        </div>
                        <div class="analytics-card">
                            <div class="analytics-value">${avgPowerDiff}</div>
                            <div class="analytics-label">平均战力差</div>
                        </div>
                        <div class="analytics-card">
                            <div class="analytics-value">${maxPowerDiff}</div>
                            <div class="analytics-label">最大战力差</div>
                        </div>
                        <div class="analytics-card">
                            <div class="analytics-value">${avgWinRateDeviation}%</div>
                            <div class="analytics-label">平均胜率偏差</div>
                        </div>
                        <div class="analytics-card">
                            <div class="analytics-value">${team1Wins}:${team2Wins}</div>
                            <div class="analytics-label">小局比分</div>
                        </div>
                    </div>
                </div>
            `;
        }

        // 获取队伍的名次标签 - 严格遵守赛制规则（16进8，8进4进2进1）
        function getTeamRankLabel(team) {
            // 检查B阶段是否全部结束（赛季结束）
            const allMatchesCompleted = matches.length > 0 && matches.every(m => m && m.completed);
            const phaseBAllCompleted = currentPhase === PhaseType.PHASE_B && allMatchesCompleted;
            
            if (currentPhase === PhaseType.PHASE_A) {
                // A阶段不显示任何特殊标签
                return null;
            }
            
            // B阶段 - 赛季已结束，显示最终名次
            if (phaseBAllCompleted) {
                // 冠军：6胜且未被淘汰（A阶段可能有0-2败）
                if (team.wins === 6 && !team.eliminated) {
                    return { label: '冠军', type: 'champion' };
                }
                
                // 亚军：5胜且被淘汰（A阶段可能有0-2败，B阶段决赛1败）
                if (team.wins === 5 && team.eliminated) {
                    return { label: '亚军', type: 'runnerUp' };
                }
                
                // 四强：4胜且被淘汰（半决赛败者）
                if (team.wins === 4 && team.eliminated) {
                    return { label: '四强', type: 'top4' };
                }
                
                // 八强：3胜且被淘汰（B阶段四分之一决赛败者）
                if (team.qualified && team.wins === 3 && team.eliminated) {
                    return { label: '八强', type: 'top8' };
                }
                
                // 十六强：A阶段被淘汰的队伍
                if (team.eliminated && !team.qualified) {
                    return { label: '十六强', type: 'top16' };
                }
            } else {
                // B阶段进行中 - 根据实际战绩显示名次
                // A阶段被淘汰的队伍显示"十六强"
                if (team.eliminated && !team.qualified) {
                    return { label: '十六强', type: 'top16' };
                }
                
                // B阶段被淘汰的队伍根据胜场数显示相应名次
                if (team.eliminated && team.qualified) {
                    if (team.wins === 5) {
                        // 决赛败者
                        return { label: '亚军', type: 'runnerUp' };
                    } else if (team.wins === 4) {
                        // 半决赛败者
                        return { label: '四强', type: 'top4' };
                    } else if (team.wins === 3) {
                        // 四分之一决赛败者
                        return { label: '八强', type: 'top8' };
                    }
                }
                
                // 其他情况不显示标签，等待赛季结束
            }
            
            return null;
        }

        // 查找冠军 - B阶段全胜的队伍（总战绩6胜，未被淘汰）
        function findChampion() {
            // 冠军：A阶段3胜 + B阶段3胜（四分之一决赛+半决赛+决赛）= 6胜
            // A阶段可能有0-2败，所以总败场可能是0-2，关键是未被淘汰
            const candidates = teams.filter(t => t && t.wins === 6 && !t.eliminated);
            return candidates.length > 0 ? candidates[0] : null;
        }
        
        // 查找亚军 - B阶段决赛失败者（总战绩5胜，已被淘汰）
        function findRunnerUp() {
            // 亚军：A阶段3胜 + B阶段2胜1败 = 5胜
            // A阶段可能有0-2败，B阶段1败（决赛），所以总败场可能是1-3
            const candidates = teams.filter(t => t && t.wins === 5 && t.eliminated);
            return candidates.length > 0 ? candidates[0] : null;
        }

        // 更新战力排行榜
        function updatePowerRanking() {
            const container = document.getElementById('teamContent');
            const sortedTeams = [...teams].sort((a, b) => b.basePower - a.basePower);
            
            // 检查赛季是否已结束
            const allMatchesCompleted = matches.length > 0 && matches.every(m => m && m.completed);
            const phaseBAllCompleted = currentPhase === PhaseType.PHASE_B && allMatchesCompleted;
            const seasonEnded = phaseBAllCompleted;
            
            // 找出真正的冠军
            const champion = seasonEnded ? findChampion() : null;
            
            let html = '<div class="power-ranking-list">';
            
            sortedTeams.forEach((team, index) => {
                const rankClass = index < 3 ? 'top-rank' : '';
                
                // 获取队伍的名次标签
                const rankLabel = getTeamRankLabel(team);
                
                // 构建名称和名次标签
                let nameLabel = team.name;
                
                // 冠军星标常显 - 显示所有获得冠军的赛季，格式为"★-1.2.3"
                if (team.championCount > 0) {
                    const seasonsStr = team.championSeasons.join('.');
                    nameLabel += `<span class="champion-star">★-${seasonsStr}</span>`;
                }
                
                // 亚军银星常显 - 显示所有获得亚军的赛季，格式为"☆-1.2.3"（与冠军星标同时显示）
                if (team.runnerUpCount > 0) {
                    const seasonsStr = team.runnerUpSeasons.join('.');
                    nameLabel += `<span class="runner-up-star">☆-${seasonsStr}</span>`;
                }
                
                // 显示其他名次标签（亚军、四强、八强等）
                if (rankLabel) {
                    nameLabel += ` <span style="color: ${getRankLabelColor(rankLabel.type)}; font-size: 10px;">[${rankLabel.label}]</span>`;
                }
                
                html += `
                    <div class="power-ranking-item ${rankClass}">
                        <span class="rank-number">#${index + 1}</span>
                        <span class="team-name-with-champion">${nameLabel}</span>
                        <span class="power-value">${team.basePower}</span>
                    </div>
                `;
            });
            
            html += '</div>';
            container.innerHTML = html;
        }
        
        // 获取名次标签的颜色
        function getRankLabelColor(type) {
            switch(type) {
                case 'champion': return '#FFD700'; // 金色
                case 'runnerUp': return '#C0C0C0'; // 银色
                case 'finalist': return '#9C27B0'; // 紫色
                case 'top4': return '#2196F3'; // 蓝色
                case 'top8': return '#FF9800'; // 橙色
                case 'top16': return '#9E9E9E'; // 灰色
                default: return '#666';
            }
        }

        // 更新结果面板
        function updateResultPanel() {
            if (!teams || teams.length === 0) return;

            // 切换A/B阶段显示
            const phaseAResults = document.getElementById('phaseAResults');
            const phaseBResults = document.getElementById('phaseBResults');
            
            if (currentPhase === PhaseType.PHASE_A) {
                if (phaseAResults) phaseAResults.style.display = 'block';
                if (phaseBResults) phaseBResults.style.display = 'none';
                updatePhaseAResults();
            } else {
                if (phaseAResults) phaseAResults.style.display = 'none';
                if (phaseBResults) phaseBResults.style.display = 'block';
                updatePhaseBResults();
            }
        }

        // 更新A阶段结果
        function updatePhaseAResults() {
            // 阶段A：3胜晋级，3败淘汰（16进8）
            teams.forEach(team => {
                if (team) {
                    if (team.wins >= 3 && !team.qualified) {
                        team.qualified = true;
                    }
                    if (team.losses >= 3 && !team.eliminated) {
                        team.eliminated = true;
                    }
                }
            });

            const qualifiedContainer = document.getElementById('qualifiedTeams');
            const undecidedContainer = document.getElementById('undecidedTeams');
            const eliminatedContainer = document.getElementById('eliminatedTeams');

            if (!qualifiedContainer || !undecidedContainer || !eliminatedContainer) return;

            const qualified = teams.filter(t => t && t.qualified && t.wins === 3);
            const undecided = teams.filter(t => t && !t.qualified && !t.eliminated);
            const eliminated = teams.filter(t => t && t.eliminated);
            
            // 按胜场数降序排列
            const sortedQualified = [...qualified].sort((a, b) => {
                if (b.wins !== a.wins) return b.wins - a.wins;
                return a.losses - b.losses;
            });
            
            const sortedUndecided = [...undecided].sort((a, b) => {
                if (b.wins !== a.wins) return b.wins - a.wins;
                return a.losses - b.losses;
            });
            
            const sortedEliminated = [...eliminated].sort((a, b) => {
                if (b.wins !== a.wins) return b.wins - a.wins;
                return a.losses - b.losses;
            });

            const qualifiedTitle = document.getElementById('qualifiedTitle');
            if (qualifiedTitle) {
                qualifiedTitle.textContent = '已晋级阶段B (3胜)';
            }

            qualifiedContainer.innerHTML = sortedQualified.map(team => `
                <div class="result-team-item qualified">
                    <span class="result-team-name">${team.name}</span>
                    <span class="result-team-record">${team.wins}胜${team.losses}败</span>
                </div>
            `).join('') || '<p style="text-align: center; color: #999; font-size: 12px; padding: 8px;">暂无</p>';

            undecidedContainer.innerHTML = sortedUndecided.map(team => `
                <div class="result-team-item">
                    <span class="result-team-name">${team.name}</span>
                    <span class="result-team-record">${team.wins}胜${team.losses}败</span>
                </div>
            `).join('') || '<p style="text-align: center; color: #999; font-size: 12px; padding: 8px;">暂无</p>';

            eliminatedContainer.innerHTML = sortedEliminated.map(team => `
                <div class="result-team-item eliminated">
                    <span class="result-team-name">${team.name}</span>
                    <span class="result-team-record">${team.wins}胜${team.losses}败</span>
                </div>
            `).join('') || '<p style="text-align: center; color: #999; font-size: 12px; padding: 8px;">暂无</p>';
        }

        // 更新B阶段结果 - 严格的1-1-2-4-8布局，不显示胜负记录
        function updatePhaseBResults() {
            const championContainer = document.getElementById('championTeams');
            const runnerUpContainer = document.getElementById('runnerUpTeams');
            const top4Container = document.getElementById('top4Teams');
            const top8Container = document.getElementById('top8Teams');
            const top16Container = document.getElementById('top16Teams');
            const championSection = document.getElementById('championSection');
            const runnerUpSection = document.getElementById('runnerUpSection');
            const top4Section = document.getElementById('top4Section');
            const top8Section = document.getElementById('top8Section');
            const top16Section = document.getElementById('top16Section');
            const championTitle = document.getElementById('championTitle');

            if (!championContainer || !runnerUpContainer || !top4Container || !top8Container || !top16Container) return;

            // 检查B阶段是否已开始
            const phaseBMatchesStarted = completedMatches.some(m => m && m.phase === PhaseType.PHASE_B);
            const allMatchesCompleted = matches.length > 0 && matches.every(m => m && m.completed);
            
            // 分类队伍 - 严格按照B阶段淘汰赛制（8→4→2→1）
            let champions = [];
            let runnerUps = [];
            let top4Teams = [];
            let top8Teams = [];
            
            // 获取所有已晋级B阶段的队伍（qualified标志在startPhaseB中设置）
            const qualifiedBTeams = teams.filter(t => t && t.qualified);
            // 获取在B阶段未被淘汰的队伍
            const activeBTeams = qualifiedBTeams.filter(t => !t.eliminated);
            // 获取在B阶段已被淘汰的队伍
            const eliminatedBTeams = qualifiedBTeams.filter(t => t.eliminated);
            
            if (allMatchesCompleted && phaseBMatchesStarted) {
                // B阶段全部结束 - 使用精确的胜负判定
                // 冠军：6胜且未被淘汰（A阶段可能有0-2败）
                const champion = findChampion();
                if (champion) champions = [champion];
                
                // 亚军：5胜且被淘汰（A阶段可能有0-2败，B阶段决赛1败）
                const runnerUp = findRunnerUp();
                if (runnerUp) runnerUps = [runnerUp];
                
                // 四强：4胜且被淘汰（半决赛败者）
                top4Teams = teams.filter(t => t && t.qualified && t.wins === 4 && t.eliminated && 
                    !(champion && t.id === champion.id) && 
                    !(runnerUp && t.id === runnerUp.id)
                ).slice(0, 4);
                
                // 八强：3胜且被淘汰（B阶段四分之一决赛败者）
                top8Teams = teams.filter(t => t && t.qualified && t.wins === 3 && t.eliminated && 
                    !(champion && t.id === champion.id) && 
                    !(runnerUp && t.id === runnerUp.id) &&
                    !top4Teams.some(t4 => t4.id === t.id)
                ).slice(0, 4);
            } else if (phaseBMatchesStarted) {
                // B阶段进行中（已有B阶段比赛完成）
                const quarterfinalMatches = completedMatches.filter(m => m && m.phase === PhaseType.PHASE_B && m.round === 1);
                const semifinalMatches = completedMatches.filter(m => m && m.phase === PhaseType.PHASE_B && m.round === 2);
                const finalMatches = completedMatches.filter(m => m && m.phase === PhaseType.PHASE_B && m.round === 3);
                
                // 找出决赛败者（亚军候选人）- 第3轮比赛的败者
                const finalMatch = finalMatches.find(m => m && m.winner);
                if (finalMatch) {
                    const finalLoser = finalMatch.winner.id === finalMatch.team1.id ? finalMatch.team2 : finalMatch.team1;
                    if (finalLoser) {
                        runnerUps = [finalLoser];
                    }
                }
                
                // 冠军：决赛中获胜的队伍，或尚未被淘汰且赢了3场B阶段比赛的
                const championCandidate = activeBTeams.find(t => t.wins === 6);
                if (championCandidate) {
                    champions = [championCandidate];
                } else if (activeBTeams.length === 1 && finalMatches.length > 0) {
                    // 决赛已结束但冠军还没被正确识别
                    champions = activeBTeams.slice(0, 1);
                }
                
                // 四强：半决赛败者（已被淘汰且wins=4），或当前存活的非决赛队伍
                const semiFinalLosers = eliminatedBTeams.filter(t => t.wins === 4);
                if (semiFinalLosers.length > 0) {
                    top4Teams = semiFinalLosers.slice(0, 4);
                } else if (semifinalMatches.length >= 2) {
                    // 半决赛已结束，但队伍可能还没被标记为eliminated
                    top4Teams = eliminatedBTeams.filter(t => t.wins >= 4).slice(0, 4);
                }
                
                // 八强：四分之一决赛败者（已被淘汰且wins=3）
                const quarterFinalLosers = eliminatedBTeams.filter(t => t.wins === 3 && !top4Teams.some(t4 => t4.id === t.id));
                if (quarterFinalLosers.length > 0) {
                    top8Teams = quarterFinalLosers.slice(0, 4);
                } else if (quarterfinalMatches.length >= 4 && top4Teams.length === 0) {
                    // 四分之一决赛已全部结束，但还没有四强
                    top8Teams = eliminatedBTeams.slice(0, 4);
                }
            } else {
                // B阶段还未开始（刚进入B阶段，没有B阶段比赛记录）
                // 所有8支晋级队伍都在八强
                top8Teams = qualifiedBTeams.slice(0, 8);
            }

            // 动态控制冠军栏标题
            if (championTitle) {
                if (allMatchesCompleted && champions.length === 1) {
                    championTitle.textContent = '冠军';
                } else if (phaseBMatchesStarted && !allMatchesCompleted && champions.length === 2) {
                    championTitle.textContent = '二强';
                } else if (phaseBMatchesStarted && !allMatchesCompleted && champions.length > 0) {
                    championTitle.textContent = '决赛队伍';
                } else {
                    championTitle.textContent = '冠军';
                }
            }
            
            // 控制各区域显示 - 严格遵守1-1-4-8布局
            if (championSection) {
                championSection.style.display = champions.length > 0 ? 'block' : 'none';
            }
            if (runnerUpSection) {
                runnerUpSection.style.display = runnerUps.length > 0 ? 'block' : 'none';
            }
            if (top4Section) {
                top4Section.style.display = top4Teams.length > 0 ? 'block' : 'none';
            }
            if (top8Section) {
                top8Section.style.display = top8Teams.length > 0 ? 'block' : 'none';
            }

            // 渲染冠军/决赛队伍（严格最多2个）- 不显示胜负记录
            championContainer.innerHTML = champions.slice(0, 2).map(team => `
                <div class="result-team-item qualified">
                    <span class="result-team-name">${team.name}</span>
                </div>
            `).join('') || '<p style="text-align: center; color: #999; font-size: 12px; padding: 8px;">暂无</p>';

            // 渲染亚军（严格1个）- 不显示胜负记录
            runnerUpContainer.innerHTML = runnerUps.slice(0, 1).map(team => `
                <div class="result-team-item playoffs">
                    <span class="result-team-name">${team.name}</span>
                </div>
            `).join('') || '<p style="text-align: center; color: #999; font-size: 12px; padding: 8px;">暂无</p>';

            // 渲染四强（严格4个）
            top4Container.innerHTML = top4Teams.slice(0, 4).map(team => `
                <div class="result-team-item">
                    <span class="result-team-name">${team.name}</span>
                </div>
            `).join('') || '<p style="text-align: center; color: #999; font-size: 12px; padding: 8px;">暂无</p>';

            // 渲染八强（严格4个，B阶段四分之一决赛败者）- 不显示胜负记录
            top8Container.innerHTML = top8Teams.slice(0, 4).map(team => `
                <div class="result-team-item">
                    <span class="result-team-name">${team.name}</span>
                </div>
            `).join('') || '<p style="text-align: center; color: #999; font-size: 12px; padding: 8px;">暂无</p>';

            // 渲染十六强（严格8个，A阶段被淘汰的队伍）- 不显示胜负记录
            const top16TeamsList = teams.filter(t => t && t.eliminated && !t.qualified).slice(0, 8);
            if (top16Section) {
                top16Section.style.display = top16TeamsList.length > 0 ? 'block' : 'none';
            }
            top16Container.innerHTML = top16TeamsList.map(team => `
                <div class="result-team-item">
                    <span class="result-team-name">${team.name}</span>
                </div>
            `).join('') || '<p style="text-align: center; color: #999; font-size: 12px; padding: 8px;">暂无</p>';
        }

        // 更新队伍数据面板（表格形式）
        function updateTeamDataPanel() {
            const container = document.getElementById('teamDataContent');
            if (!container || !teams || teams.length === 0) return;

            // 检查赛季是否已结束
            const allMatchesCompleted = matches.length > 0 && matches.every(m => m && m.completed);
            const phaseBAllCompleted = currentPhase === PhaseType.PHASE_B && allMatchesCompleted;
            const seasonEnded = phaseBAllCompleted;
            
            // 找出真正的冠军
            const champion = seasonEnded ? findChampion() : null;

            let html = '<table class="team-data-table">';
            html += `
                <thead>
                    <tr>
                        <th>排名</th>
                        <th>队伍</th>
                        <th>大场胜率</th>
                        <th>小局胜率</th>
                        <th>以弱胜强</th>
                        <th>荣誉记录</th>
                        <th>赛季最高</th>
                        <th>历史最高</th>
                        <th>历史最低</th>
                        <th>赛季变动</th>
                    </tr>
                </thead>
                <tbody>
            `;

            // 按基础战力排序
            const sortedTeams = [...teams].sort((a, b) => b.basePower - a.basePower);

            sortedTeams.forEach((team, index) => {
                // 计算大场胜率（历史累计，1位小数）
                const matchWinRate = team.historicalTotalMatches > 0 ? 
                    ((team.historicalMatchWins / team.historicalTotalMatches) * 100).toFixed(1) : '0.0';
                // 计算小局胜率（历史累计，1位小数）
                const gameWinRate = team.historicalTotalGames > 0 ? 
                    ((team.historicalTotalWins / team.historicalTotalGames) * 100).toFixed(1) : '0.0';
                // 以弱胜强次数（历史累计）
                const upsetWinCount = team.historicalUpsetsWon > 0 ? `${team.historicalUpsetsWon}次` : '0次';
                // 赛季变动 = 当前基础战力 - 本赛季初始战力
                const seasonChange = team.basePower - (team.powerHistory.length > 0 ? team.powerHistory[0] : team.basePower);
                const changeColor = seasonChange >= 0 ? '#2e7d32' : '#c62828';
                const changeSign = seasonChange >= 0 ? '+' : '';
                const rankClass = index < 3 ? 'top-rank' : '';
                
                // 构建荣誉记录字符串 "冠军-亚军-四强-八强-十六强"（历史累计）
                const honorRecord = `${team.championCount}-${team.runnerUpCount}-${team.top4Count}-${team.top8Count}-${team.top16Count}`;
                
                // 构建队伍名称显示 - 冠军星标作为队名的一部分常显
                let teamNameDisplay = team.name;
                
                // 冠军星标常显 - 显示所有获得冠军的赛季，格式为"★-1.2.3"
                if (team.championCount > 0) {
                    const seasonsStr = team.championSeasons.join('.');
                    teamNameDisplay += `<span class="champion-star">★-${seasonsStr}</span>`;
                }
                
                // 亚军银星常显 - 显示所有获得亚军的赛季，格式为"☆-1.2.3"（与冠军星标同时显示）
                if (team.runnerUpCount > 0) {
                    const seasonsStr = team.runnerUpSeasons.join('.');
                    teamNameDisplay += `<span class="runner-up-star">☆-${seasonsStr}</span>`;
                }
                
                // 获取名次标签（仅赛季结束时显示）
                const rankLabel = getTeamRankLabel(team);
                if (rankLabel) {
                    teamNameDisplay += ` <span style="color: ${getRankLabelColor(rankLabel.type)}; font-size: 10px;">[${rankLabel.label}]</span>`;
                }

                html += `
                    <tr class="${rankClass}">
                        <td>#${index + 1}</td>
                        <td>${teamNameDisplay}</td>
                        <td>${matchWinRate}%</td>
                        <td>${gameWinRate}%</td>
                        <td>${upsetWinCount}</td>
                        <td style="font-weight: 600; color: #2196F3;">${honorRecord}</td>
                        <td>${team.seasonHighestPower}</td>
                        <td>${team.highestPower}</td>
                        <td>${team.lowestPower}</td>
                        <td style="color: ${changeColor}; font-weight: 600;">${changeSign}${seasonChange}</td>
                    </tr>
                `;
            });

            html += '</tbody></table>';
            container.innerHTML = html;
        }

        // 更新历史面板
        function updateHistoryPanel() {
            const container = document.getElementById('historyContent');
            const paginationEl = document.getElementById('historyPagination');

            if (!container) return;

            if (!completedMatches || completedMatches.length === 0) {
                container.innerHTML = '<p class="status-message info">暂无比赛记录</p>';
                if (paginationEl) paginationEl.style.display = 'none';
                return;
            }

            if (paginationEl) paginationEl.style.display = 'flex';
            
            const totalPages = Math.ceil(completedMatches.length / historyPageSize);
            if (historyCurrentPage > totalPages) {
                historyCurrentPage = totalPages;
            }
            
            const startIndex = (historyCurrentPage - 1) * historyPageSize;
            const endIndex = Math.min(startIndex + historyPageSize, completedMatches.length);
            const pageMatches = completedMatches.slice(startIndex, endIndex).reverse();

            const pageInfoEl = document.getElementById('pageInfo');
            const prevBtn = document.getElementById('prevPageBtn');
            const nextBtn = document.getElementById('nextPageBtn');
            
            if (pageInfoEl) pageInfoEl.textContent = `${historyCurrentPage}/${totalPages}`;
            if (prevBtn) prevBtn.disabled = historyCurrentPage <= 1;
            if (nextBtn) nextBtn.disabled = historyCurrentPage >= totalPages;

            let html = '<div class="history-list">';

            pageMatches.forEach(match => {
                if (!match || !match.team1 || !match.team2 || !match.winner) return;
                
                const isTeam1Winner = match.winner.id === match.team1.id;
                const phaseLabel = match.phase === PhaseType.PHASE_B ? 'B' : 'A';
                const matchId = `${match.season}${phaseLabel}-${match.matchNumber}`;
                
                html += `
                    <div class="history-match-card">
                        <span class="history-season-tag">第${match.season}赛季</span>
                        <div class="history-match-header">
                            <span class="history-match-number">${matchId}</span>
                        </div>
                        <div class="history-match-teams">
                            <span class="history-team ${isTeam1Winner ? 'winner' : 'loser'}">
                                ${match.team1.name}
                            </span>
                            <span class="history-score">${match.team1Score} - ${match.team2Score}</span>
                            <span class="history-team ${!isTeam1Winner ? 'winner' : 'loser'}">
                                ${match.team2.name}
                            </span>
                        </div>
                        <div class="history-games-summary">
                            战绩: ${match.team1.name} (${match.team1.wins}胜${match.team1.losses}败) | 
                            ${match.team2.name} (${match.team2.wins}胜${match.team2.losses}败)
                        </div>
                    </div>
                `;
            });

            html += '</div>';
            container.innerHTML = html;
        }

        // 切换历史页
        function changeHistoryPage(delta) {
            const totalPages = Math.ceil(completedMatches.length / historyPageSize);
            const newPage = historyCurrentPage + delta;
            
            if (newPage >= 1 && newPage <= totalPages) {
                historyCurrentPage = newPage;
                updateHistoryPanel();
            }
        }

        // 结束赛季
        function endSeason() {
            // 找出冠军、亚军 - 使用精确的胜负判定
            const champion = findChampion();
            const runnerUp = findRunnerUp();
            
            // 四强：进入过B阶段（qualified=true）且是半决赛败者（4胜）的队伍
            const top4 = teams.filter(t => t && t.qualified && t.wins === 4 && 
                !(champion && t.id === champion.id) && 
                !(runnerUp && t.id === runnerUp.id)
            );
            
            // 八强：B阶段四分之一决赛败者（qualified=true，wins=3，即只赢了A阶段）
            const top8 = teams.filter(t => t && t.qualified && t.wins === 3 && 
                !(champion && t.id === champion.id) && 
                !(runnerUp && t.id === runnerUp.id) &&
                !top4.some(t4 => t4.id === t.id)
            );

            // 冠军（6胜0-1败）
            if (champion) {
                champion.championCount++;
                champion.championSeasons.push(currentSeason); // 记录获得冠军的赛季
                champion.basePower += 15;
            }

            // 亚军（5胜1-2败）
            if (runnerUp) {
                runnerUp.runnerUpCount++;
                runnerUp.runnerUpSeasons.push(currentSeason); // 记录获得亚军的赛季
                runnerUp.basePower += 10;
            }

            // 4强（半决赛败者，最多4个）
            top4.slice(0, 4).forEach(team => {
                team.top4Count++;
                team.basePower += 8;
            });

            // 8强（B阶段四分之一决赛败者，最多4个）
            top8.slice(0, 4).forEach(team => {
                team.top8Count++;
                team.basePower += 4;
            });

            // 16强（A阶段被淘汰的队伍，最多8个）
            const top16 = teams.filter(t => t && t.eliminated && !t.qualified);
            top16.slice(0, 8).forEach(team => {
                team.top16Count++;
                team.basePower += 2;
            });

            updateOperationStatus(`第${currentSeason}赛季结束！冠军: ${champion?.name || '未知'}`);
            updatePowerRanking();
            updateTeamDataPanel();
            updateResultPanel();

            document.getElementById('endSeasonBtn').disabled = true;
            document.getElementById('startMatchBtn').disabled = true;

            // 询问是否进入下赛季
            setTimeout(() => {
                if (confirm(`第${currentSeason}赛季已结束！\n\n是否进入第${currentSeason + 1}赛季？`)) {
                    startNextSeason();
                }
            }, 1000);
        }

        // 开始下一个赛季
        function startNextSeason() {
            currentSeason++;
            currentPhase = PhaseType.PHASE_A;
            currentState = GameState.GROUPING;

            // 重置队伍状态但保留战力和历史累计统计
            teams.forEach(team => {
                team.wins = 0;
                team.losses = 0;
                team.qualified = false;
                team.eliminated = false;
                team.defenseModeActive = false;
                team.defenseModeBonus = 0;
                team.upsetBonus = 0;
                team.totalGames = 0;
                team.totalWins = 0;
                team.totalMatches = 0;
                team.matchWins = 0;
                team.upsetsWon = 0;
                team.upsetsLost = 0;
                // 重置powerHistory，以当前战力作为新赛季的起点
                team.powerHistory = [team.basePower];
                team.seasonHighestPower = team.basePower;
                // historicalTotalGames, historicalTotalWins, historicalTotalMatches, 
                // historicalMatchWins, historicalUpsetsWon 保留不清空
            });

            matches = [];
            currentMatch = null;
            completedMatches = []; // 清空当前赛季的比赛记录
            historyCurrentPage = 1;
            // 新赛季的计数器从0开始
            seasonMatchCounters[currentSeason] = 0;
            
            // allSeasonMatches 保留，不清空 - 用于跨赛季历史统计

            updatePhaseDisplay();
            updatePowerRanking();
            updateTeamDataPanel();
            updateResultPanel();
            updateSchedulePanel();
            updateHistoryPanel();

            // 自动生成新的随机分组
            generateRandomMatches();
            updateOperationStatus(`第${currentSeason}赛季开始！已自动分组，请点击确认开始比赛`);
            document.getElementById('confirmBtn').disabled = false;
        }

        // 初始化
        window.onload = function() {
            initTeams();
            updatePhaseDisplay();
        };
    </script>
</body>
</html>
